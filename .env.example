# =============================================================================
# Docker Compose (prod only — docker-compose.prod.yml)
# =============================================================================
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
MONGO_ROOT_USER=
MONGO_ROOT_PASS=

# =============================================================================
# API (apps/api)
# =============================================================================
PORT=4000
CORS_ORIGIN=http://localhost:3003
RABBITMQ_URL=amqp://<RABBITMQ_USER>:<RABBITMQ_PASS>@rabbitmq:5672
MONGODB_URI=mongodb://<MONGO_ROOT_USER>:<MONGO_ROOT_PASS>@mongo:27017/iot?authSource=admin

# =============================================================================
# Simulator (apps/simulator)
# =============================================================================
# RABBITMQ_URL=amqp://guest:guest@localhost:5672
EMIT_INTERVAL_MS=500

# =============================================================================
# Web (apps/web)
# =============================================================================
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
